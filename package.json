{
  "name": "holder-rewards-cloudflare",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Browser-deployable Cloudflare Worker release of Holder Rewards.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "node scripts/deploy.mjs",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "cloudflare": {
    "bindings": {
      "DISCORD_BOT_TOKEN": {
        "description": "Add this as a Cloudflare build secret. The deploy script securely installs it as the Worker's runtime secret."
      }
    }
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "uqr": "^0.1.3",
    "viem": "^2.37.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "typescript": "^5.7.3",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.35.3"
    }
  }
}
